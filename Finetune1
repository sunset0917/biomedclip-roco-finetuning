ficando val\"):\n    path = os.path.join(VAL_IMG, name)\n    try:\n        with Image.open(path) as img:\n            img.verify()\n        valid_val.append(name)\n    except Exception:\n        pass\n\ndf_val = df_val[df_val[\"name\"].isin(set(valid_val))].reset_index(drop=True)\nprint(f\"Número de imágenes para validación: {len(df_val)} \")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-01T23:46:24.042069Z","iopub.execute_input":"2026-05-01T23:46:24.042835Z","iopub.status.idle":"2026-05-01T23:47:56.883076Z","shell.execute_reply.started":"2026-05-01T23:46:24.042805Z","shell.execute_reply":"2026-05-01T23:47:56.882403Z"}},"outputs":[{"name":"stderr","text":"Verificando val: 100%|██████████| 8175/8175 [01:32<00:00, 88.30it/s]","output_type":"stream"},{"name":"stdout","text":"Número de imágenes para validación: 8175 \n","output_type":"stream"},{"name":"stderr","text":"\n","output_type":"stream"}],"execution_count":15},{"cell_type":"code","source":"class ValDataset(Dataset):\n    def __init__(self, df, preprocess, tokenizer):\n        self.df         = df.reset_index(drop=True)\n        self.preprocess = preprocess\n        self.tokenizer  = tokenizer\n\n    def __len__(self):\n        return len(self.df)\n\n    def __getitem__(self, idx):\n        row   = self.df.iloc[idx]\n        image = Image.open(row[\"image_path\"]).convert(\"RGB\")\n        image = self.preprocess(image)\n        text  = self.tokenizer(row[\"caption\"], context_length=256)[0]\n        return image, text\n\nval_dataset = ValDataset(df_val, preprocess_val, tokenizer)\nval_loader  = DataLoader(\n    val_dataset,\n    batch_size=64,  \n    shuffle=False,\n    num_workers=2,\n    pin_memory=True\n)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-01T23:49:43.425362Z","iopub.execute_input":"2026-05-01T23:49:43.425701Z","iopub.status.idle":"2026-05-01T23:49:43.433081Z","shell.execute_reply.started":"2026-05-01T23:49:43.425671Z","shell.execute_reply":"2026-05-01T23:49:43.432398Z"}},"outputs":[],"execution_count":16},{"cell_type":"code","source":"model.eval()\n\nall_image_features = []\nall_text_features  = []\n\nwith torch.no_grad():\n    for images, texts in tqdm(val_loader, desc=\"Extrayendo embeddings\"):\n        images = images.to(device)\n        texts  = texts.to(device)\n\n        img_feat, txt_feat, _ = model(images, texts)\n\n        # Normalizar (CLIP siempre trabaja con embeddings normalizados)\n        img_feat = img_feat / img_feat.norm(dim=-1, keepdim=True)\n        txt_feat = txt_feat / txt_feat.norm(dim=-1, keepdim=True)\n\n        all_image_features.append(img_feat.cpu())\n        all_text_features.append(txt_feat.cpu())\n\nimage_features = torch.cat(all_image_features)  # (N, 512)\ntext_features  = torch.cat(all_text_features)   # (N, 512)\n\nprint(f\"Embeddings: {image_features.shape}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-01T23:49:54.786735Z","iopub.execute_input":"2026-05-01T23:49:54.787539Z","iopub.status.idle":"2026-05-01T23:53:48.403706Z","shell.execute_reply.started":"2026-05-01T23:49:54.787502Z","shell.execute_reply":"2026-05-01T23:53:48.402982Z"}},"outputs":[{"name":"stderr","text":"Extrayendo embeddings: 100%|██████████| 128/128 [03:53<00:00,  1.82s/it]","output_type":"stream"},{"name":"stdout","text":"Embeddings: torch.Size([8175, 512])\n","output_type":"stream"},{"name":"stderr","text":"\n","output_type":"stream"}],"execution_count":17},{"cell_type":"code","source":"# ─── 4. Recall@K ──────────────────────────────────────────────────\ndef recall_at_k(image_features, text_features, ks=(1, 5, 10)):\n    \"\"\"\n    Para cada imagen, busca su caption correcto entre los K más similares.\n    El ground truth es la diagonal (imagen i ↔ texto i).\n    \"\"\"\n    # Matriz de similitud (N x N)\n    sim_matrix = image_features @ text_features.T  # cosine sim (ya normalizados)\n\n    results = {}\n    N = sim_matrix.shape[0]\n\n    for k in ks:\n        # Image → Text